{
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/before-shell-execution.js",
        "event": "beforeShellExecution",
        "description": "Block dev servers outside tmux to prevent agent hanging"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/hooks/after-shell-execution.js",
        "event": "afterShellExecution",
        "description": "Log build completions and PR URLs"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/before-read-file.js",
        "event": "beforeReadFile",
        "description": "Warn when reading sensitive files (.env, .key, .pem)"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.js",
        "event": "beforeSubmitPrompt",
        "description": "Detect accidentally pasted API keys in prompts"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop.js",
        "event": "stop",
        "description": "Audit modified files for console.log before session ends"
      }
    ]
  }
}
